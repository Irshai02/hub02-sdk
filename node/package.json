{
  "name": "@hub02/sdk",
  "version": "0.4.0",
  "description": "Hub02 tool-identity SDK — read the signed-in user on the client and verify Hub02 identity tokens (Ed25519) on your backend.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Irshai02/hub02-sdk.git",
    "directory": "node"
  },
  "homepage": "https://github.com/Irshai02/hub02-sdk/tree/main/node#readme",
  "keywords": [
    "hub02",
    "sso",
    "identity",
    "jwt",
    "ed25519",
    "auth"
  ],
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "main": "./dist/client.cjs",
  "module": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "unpkg": "./dist/sdk.global.js",
  "jsdelivr": "./dist/sdk.global.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "jose": "^5.9.6"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.31",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
